---
import { Image } from "astro:assets";
import aboutImg from '../assets/aboutimg.jpg';
---
<section id="about" class="py-24 bg-[#f8f9f7] overflow-hidden">
    <div class="container mx-auto px-6 md:px-12">

        <div class="bg-white/30 backdrop-blur-3xl rounded-[3rem] sm:rounded-[4rem] p-6 sm:p-10 md:p-16 lg:p-20 border border-white/50 relative reveal overflow-hidden shadow-2xl" data-aos="fade-up">

            <div class="absolute -top-20 -right-20 w-40 h-40 sm:w-80 sm:h-80 bg-[#a4b494]/10 rounded-full blur-[60px] sm:blur-[100px]"></div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-16 items-center relative z-10">

                <div class="relative group">
                    <div class="rounded-[2rem] sm:rounded-[3rem] overflow-hidden shadow-2xl transition-transform duration-700 group-hover:scale-[1.02]">
                        <Image 
                        src={aboutImg}
                        alt="About CholoroFy"
                        class="w-full h-80 sm:h-100 lg:h-125 object-cover"
                        />
                    </div>
                </div>

                <div>
                    <h2 class="text-[10px] font-black uppercase tracking-[0.5em] text-[#4b5d3f] mb-4 sm:mb-6">About the Movement</h2>
                    <h3 class="text-3xl sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#1a1c19] leading-[1] mb-6 sm:mb-8">
                        Membangun Kota yang <br> <span class="text-[#a4b494]">Bisa Bernapas Sendiri.</span>
                    </h3>
                    <p class="text-gray-500 text-base sm:text-lg leading-relaxed mb-8 sm:mb-10 font-medium">
                        Cholorofy menggabungkan kecerdasan buatan dengan sistem biologis klorofil untuk menciptakan infrastruktur yang aktif menyerap karbon dan menghasilkan energi bersih secara mandiri.
                    </p>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
                        <div class="p-6 rounded-3xl bg-white/40 backdrop-blur-md border border-white/40 group hover:bg-[#4b5d3f] hover:text-white transition-all">
                            <p class="text-2xl sm:text-3xl font-black mb-1">12M+</p>
                            <p class="text-[9px] font-black opacity-50 uppercase tracking-widest">CO2 Reduced</p>
                        </div>
                        <div class="p-6 rounded-3xl bg-white/40 backdrop-blur-md border border-white/40 group hover:bg-[#4b5d3f] hover:text-white transition-all">
                            <p class="text-2xl sm:text-3xl font-black mb-1">98.4%</p>
                            <p class="text-[9px] font-black opacity-50 uppercase tracking-widest">Efficiency</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>